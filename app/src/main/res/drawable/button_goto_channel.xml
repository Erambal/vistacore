<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused: gold background with bold border -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#33FFB300" />
            <stroke android:width="2dp" android:color="@color/accent_gold" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- Pressed: brighter gold fill -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#55FFB300" />
            <stroke android:width="2dp" android:color="@color/accent_gold" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- Default: dark with subtle border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#22FFFFFF" />
            <stroke android:width="1dp" android:color="#44FFFFFF" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
