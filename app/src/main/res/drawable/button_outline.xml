<?xml version="1.0" encoding="utf-8"?>
<!-- Outlined button; fills gold on focus for D-pad visibility. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_gold" />
            <stroke android:width="2dp" android:color="@color/accent_gold" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#33FFB300" />
            <stroke android:width="2dp" android:color="@color/accent_gold" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="2dp" android:color="#55FFFFFF" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</selector>
