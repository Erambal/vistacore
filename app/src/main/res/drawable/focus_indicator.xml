<?xml version="1.0" encoding="utf-8"?>
<!-- Transparent by default, gold stroke on focus. Applied as the background
     on compound buttons (RadioButton, CheckBox, Switch) via theme styles so
     every control in Settings gets a visible gold focus border. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="3dp" android:color="@color/focus_ring" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
