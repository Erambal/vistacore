<?xml version="1.0" encoding="utf-8"?>
<!-- Transparent foreground that draws a thick gold ring only when focused.
     Used on buttons whose backgroundTint hides the normal focus state, so the
     cursor position is obvious. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="10dp" />
            <stroke android:width="5dp" android:color="@color/accent_gold" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
