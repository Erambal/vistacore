<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused: gold border + gold left accent bar + elevated background -->
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/card_background_elevated" />
                    <corners android:radius="8dp" />
                    <stroke android:width="3dp" android:color="@color/focus_ring" />
                </shape>
            </item>
            <item android:width="4dp" android:gravity="start">
                <shape android:shape="rectangle">
                    <solid android:color="@color/accent_gold" />
                    <corners android:topLeftRadius="8dp" android:bottomLeftRadius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Selected (activated): visible gold tint so active section is clear -->
    <item android:state_activated="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#44FFB300" />
                    <corners android:radius="8dp" />
                    <stroke android:width="1dp" android:color="#55FFB300" />
                </shape>
            </item>
            <item android:width="4dp" android:gravity="start">
                <shape android:shape="rectangle">
                    <solid android:color="@color/accent_gold" />
                    <corners android:topLeftRadius="8dp" android:bottomLeftRadius="8dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Default: transparent -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
