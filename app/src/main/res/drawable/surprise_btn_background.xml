<?xml version="1.0" encoding="utf-8"?>
<!--
  Big gold pill button used by the Surprise Me hero card. Focused state
  brightens to gold_light so D-pad navigation has a clear visual signal.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_gold_light" />
            <corners android:radius="14dp" />
            <stroke android:width="2dp" android:color="@color/accent_gold" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_gold_light" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/accent_gold" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
