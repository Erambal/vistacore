<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TV Guide"
            android:textSize="32sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-light" />

        <!-- Current time -->
        <TextClock
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="h:mm a"
            android:textSize="24sp"
            android:textColor="@color/accent_gold"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Timeline header -->
    <LinearLayout
        android:id="@+id/timeline_header"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/surface_dark"
        android:gravity="center_vertical"
        android:paddingStart="240dp">

        <!-- Time slots filled programmatically -->
    </LinearLayout>

    <!-- EPG Grid: channels on left, programs scrolling right -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/epg_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false" />

    <!-- Loading -->
    <LinearLayout
        android:id="@+id/epg_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminateTint="@color/accent_gold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading TV Guide…"
            android:textSize="22sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="16dp" />
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/epg_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="No guide data available.\nAdd an EPG URL in Settings."
        android:textSize="22sp"
        android:textColor="@color/text_secondary"
        android:lineSpacingExtra="8dp"
        android:visibility="gone" />
</LinearLayout>
