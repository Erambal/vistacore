<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nf_bg">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ===== Top bar: clock (left) + actions (right) ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="48dp"
        android:paddingEnd="40dp">

        <TextView
            android:id="@+id/hs_clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textColor="@color/nf_cream"
            android:fontFamily="sans-serif-thin"
            android:letterSpacing="0.04" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/hs_btn_search"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/nf_chip_selector"
            android:paddingStart="20dp"
            android:paddingEnd="22dp"
            android:layout_marginStart="12dp"
            android:nextFocusLeft="@id/hs_btn_search"
            android:focusable="true"
            android:focusableInTouchMode="true">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_voice_search"
                android:tint="@color/nf_cream"
                android:layout_marginEnd="10dp"
                android:contentDescription="@null" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_action_search"
                android:textSize="16sp"
                android:textColor="@color/nf_cream"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/hs_btn_help"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/nf_chip_selector"
            android:paddingStart="20dp"
            android:paddingEnd="22dp"
            android:layout_marginStart="12dp"
            android:focusable="true"
            android:focusableInTouchMode="true">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_remote_help"
                android:tint="@color/nf_cream"
                android:layout_marginEnd="10dp"
                android:contentDescription="@null" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_action_help"
                android:textSize="16sp"
                android:textColor="@color/nf_cream"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/hs_btn_settings"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/nf_chip_selector"
            android:paddingStart="20dp"
            android:paddingEnd="22dp"
            android:layout_marginStart="12dp"
            android:nextFocusRight="@id/hs_btn_settings"
            android:focusable="true"
            android:focusableInTouchMode="true">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_settings"
                android:tint="@color/nf_cream"
                android:layout_marginEnd="10dp"
                android:contentDescription="@null" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_action_settings"
                android:textSize="16sp"
                android:textColor="@color/nf_cream"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===== Hero preview (reflects the focused tile) ===== -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="220dp">

        <ImageView
            android:id="@+id/hs_backdrop"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_left_scrim" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_bottom_scrim" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="bottom|start"
            android:paddingStart="48dp"
            android:paddingEnd="320dp"
            android:paddingBottom="18dp">

            <TextView
                android:id="@+id/hs_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@color/nf_amber"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/hs_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="38sp"
                android:textColor="@color/nf_cream"
                android:fontFamily="sans-serif-black"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/hs_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="@color/nf_cream_dim"
                android:fontFamily="sans-serif"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/hs_prompt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_press_ok_to_watch"
                android:textSize="15sp"
                android:textColor="@color/nf_amber"
                android:fontFamily="sans-serif-medium"
                android:drawablePadding="8dp"
                android:layout_marginTop="6dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- ===== Scrollable rows ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="48dp">

            <!-- Continue Watching (hidden until there is history) -->
            <LinearLayout
                android:id="@+id/hs_continue_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout style="@style/NfRowHeader">
                    <View android:layout_width="6dp" android:layout_height="26dp"
                        android:layout_marginEnd="12dp" android:background="@color/nf_accent_continue" />
                    <TextView style="@style/NfRowHeaderText" android:text="@string/home_continue" />
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/hs_continue_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:clipToPadding="false"
                    android:paddingEnd="48dp"
                    android:layout_marginBottom="12dp" />
            </LinearLayout>

            <LinearLayout style="@style/NfRowHeader">
                <View android:layout_width="6dp" android:layout_height="26dp"
                    android:layout_marginEnd="12dp" android:background="@color/nf_accent_live" />
                <TextView android:id="@+id/hs_live_header" style="@style/NfRowHeaderText" android:text="@string/home_lane_live" />
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/hs_live_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:paddingEnd="48dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout style="@style/NfRowHeader">
                <View android:layout_width="6dp" android:layout_height="26dp"
                    android:layout_marginEnd="12dp" android:background="@color/nf_accent_movies" />
                <TextView android:id="@+id/hs_movies_header" style="@style/NfRowHeaderText" android:text="@string/home_lane_movies" />
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/hs_movies_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:paddingEnd="48dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout style="@style/NfRowHeader">
                <View android:layout_width="6dp" android:layout_height="26dp"
                    android:layout_marginEnd="12dp" android:background="@color/nf_accent_shows" />
                <TextView android:id="@+id/hs_shows_header" style="@style/NfRowHeaderText" android:text="@string/home_lane_shows" />
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/hs_shows_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:paddingEnd="48dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout style="@style/NfRowHeader">
                <View android:layout_width="6dp" android:layout_height="26dp"
                    android:layout_marginEnd="12dp" android:background="@color/nf_accent_apps" />
                <TextView style="@style/NfRowHeaderText" android:text="@string/section_all_apps" />
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/hs_apps_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:paddingEnd="48dp"
                android:layout_marginBottom="12dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

  </LinearLayout>

    <FrameLayout
        android:id="@+id/hs_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/nf_bg"
        android:visibility="gone">

        <com.vistacore.launcher.ui.BouncingDotsView
            android:layout_width="120dp"
            android:layout_height="56dp"
            android:layout_gravity="center" />
    </FrameLayout>

</FrameLayout>
