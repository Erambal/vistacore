<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Fullscreen live player — the TV is already "on" -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/tvon_player"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:resize_mode="fit" />

    <View
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:layout_gravity="top"
        android:background="@drawable/gradient_top_scrim" />

    <View
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_bottom_scrim" />

    <!-- Top-left: what's playing now -->
    <LinearLayout
        android:id="@+id/tvon_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="top|start"
        android:paddingStart="48dp"
        android:paddingEnd="48dp"
        android:paddingTop="32dp">

        <TextView
            android:id="@+id/tvon_channel_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/accent_gold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/tvon_channel_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="34sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvon_now_playing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Top-right: big jump buttons -->
    <LinearLayout
        android:id="@+id/tvon_topbar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="top|end"
        android:paddingTop="30dp"
        android:paddingEnd="48dp">

        <Button
            android:id="@+id/tvon_btn_search"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="@string/home_action_search"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/home_tile_selector"
            android:drawableStart="@drawable/ic_voice_search"
            android:drawableTint="@color/text_primary"
            android:drawablePadding="10dp"
            android:paddingStart="22dp"
            android:paddingEnd="24dp"
            android:layout_marginEnd="14dp"
            android:focusable="true" />

        <Button
            android:id="@+id/tvon_btn_movies"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="@string/home_lane_movies"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/home_tile_selector"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginEnd="14dp"
            android:focusable="true" />

        <Button
            android:id="@+id/tvon_btn_shows"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="@string/home_lane_shows"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/home_tile_selector"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginEnd="14dp"
            android:focusable="true" />

        <Button
            android:id="@+id/tvon_btn_apps"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="@string/section_all_apps"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/home_tile_selector"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginEnd="14dp"
            android:focusable="true" />

        <Button
            android:id="@+id/tvon_btn_settings"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="@string/home_action_settings"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/home_tile_selector"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:focusable="true" />
    </LinearLayout>

    <!-- Bottom: channels -->
    <LinearLayout
        android:id="@+id/tvon_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/home_tvon_channels_hint"
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="48dp"
            android:paddingBottom="6dp" />

        <Button
            android:id="@+id/tvon_category"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="240dp"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/card_selector"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:layout_marginStart="48dp"
            android:layout_marginBottom="6dp"
            android:gravity="center_vertical|start"
            android:singleLine="true"
            android:ellipsize="end"
            android:focusable="true" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="170dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/tvon_ribbon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:paddingStart="48dp"
                android:paddingEnd="48dp"
                android:paddingTop="8dp"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/tvon_no_results"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/home_no_channels"
                android:textSize="18sp"
                android:textColor="@color/text_hint"
                android:fontFamily="sans-serif-light"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <!-- Buffering spinner (over the video, not a full-screen cover) -->
    <ProgressBar
        android:id="@+id/tvon_buffering"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/accent_gold"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/tvon_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_dark"
        android:visibility="gone">

        <com.vistacore.launcher.ui.BouncingDotsView
            android:layout_width="120dp"
            android:layout_height="56dp"
            android:layout_gravity="center" />
    </FrameLayout>

</FrameLayout>
