<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- ExoPlayer View — controller disabled, we use our own -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:resize_mode="fit" />

    <!-- Channel info overlay (shown briefly on channel switch) -->
    <LinearLayout
        android:id="@+id/channel_info_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/card_default"
        android:padding="20dp"
        android:visibility="gone">

        <!-- Channel number -->
        <TextView
            android:id="@+id/overlay_channel_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="32sp"
            android:textColor="@color/accent_gold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginEnd="16dp" />

        <ImageView
            android:id="@+id/overlay_channel_logo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:contentDescription="@string/cd_channel_logo" />

        <TextView
            android:id="@+id/overlay_channel_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="28sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- Player controls overlay (our own, not ExoPlayer's) -->
    <LinearLayout
        android:id="@+id/controls_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/ctrl_channel_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btn_prev_channel"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_skip_previous"
                android:background="@drawable/card_selector"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:contentDescription="Previous channel"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <ImageButton
                android:id="@+id/btn_play_pause"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_pause"
                android:background="@drawable/card_selector"
                android:padding="12dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:scaleType="centerInside"
                android:contentDescription="Play/Pause"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <ImageButton
                android:id="@+id/btn_next_channel"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_skip_next"
                android:background="@drawable/card_selector"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:contentDescription="Next channel"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <View
                android:layout_width="32dp"
                android:layout_height="1dp" />

            <ImageButton
                android:id="@+id/btn_audio_track"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_audio_track"
                android:background="@drawable/card_selector"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:contentDescription="Audio language"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <ImageButton
                android:id="@+id/btn_subtitle_track"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_subtitles"
                android:background="@drawable/card_selector"
                android:padding="12dp"
                android:layout_marginStart="8dp"
                android:scaleType="centerInside"
                android:contentDescription="Subtitles"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <ImageButton
                android:id="@+id/btn_quality"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_quality"
                android:background="@drawable/card_selector"
                android:padding="12dp"
                android:layout_marginStart="8dp"
                android:scaleType="centerInside"
                android:contentDescription="Video quality"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <ImageButton
                android:id="@+id/btn_content_filter"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_content_filter_off"
                android:background="@drawable/card_selector"
                android:padding="12dp"
                android:layout_marginStart="8dp"
                android:scaleType="centerInside"
                android:contentDescription="Content filter"
                android:focusable="true"
                android:focusableInTouchMode="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- VOD scrub bar overlay (movies/shows only) -->
    <LinearLayout
        android:id="@+id/scrub_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#DD000000"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        android:visibility="gone">

        <!-- Title -->
        <TextView
            android:id="@+id/scrub_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="12dp" />

        <!-- Seek bar -->
        <SeekBar
            android:id="@+id/scrub_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="1000"
            android:progressTint="@color/accent_gold"
            android:thumbTint="@color/accent_gold"
            android:progressBackgroundTint="#44FFFFFF"
            android:focusable="true"
            android:focusableInTouchMode="true" />

        <!-- Time row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/scrub_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Seek speed indicator -->
            <TextView
                android:id="@+id/scrub_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@color/accent_gold"
                android:fontFamily="sans-serif-medium"
                android:visibility="gone" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/scrub_total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@color/text_hint"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <!-- Playback controls row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp">

            <ImageButton
                android:id="@+id/scrub_rewind"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_skip_previous"
                android:background="@drawable/card_selector"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:contentDescription="Rewind"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <ImageButton
                android:id="@+id/scrub_play_pause"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_pause"
                android:background="@drawable/card_selector"
                android:padding="12dp"
                android:layout_marginStart="32dp"
                android:layout_marginEnd="32dp"
                android:scaleType="centerInside"
                android:contentDescription="Play/Pause"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <ImageButton
                android:id="@+id/scrub_forward"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_skip_next"
                android:background="@drawable/card_selector"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:contentDescription="Fast Forward"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <View
                android:layout_width="32dp"
                android:layout_height="1dp" />

            <ImageButton
                android:id="@+id/scrub_audio_track"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_audio_track"
                android:background="@drawable/card_selector"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:contentDescription="Audio language"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <ImageButton
                android:id="@+id/scrub_subtitle_track"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_subtitles"
                android:background="@drawable/card_selector"
                android:padding="12dp"
                android:layout_marginStart="8dp"
                android:scaleType="centerInside"
                android:contentDescription="Subtitles"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <ImageButton
                android:id="@+id/scrub_quality"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_quality"
                android:background="@drawable/card_selector"
                android:padding="12dp"
                android:layout_marginStart="8dp"
                android:scaleType="centerInside"
                android:contentDescription="Video quality"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <ImageButton
                android:id="@+id/scrub_content_filter"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                android:src="@drawable/ic_content_filter_off"
                android:background="@drawable/card_selector"
                android:padding="12dp"
                android:layout_marginStart="8dp"
                android:scaleType="centerInside"
                android:contentDescription="Content filter"
                android:focusable="true"
                android:focusableInTouchMode="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- Loading spinner -->
    <ProgressBar
        android:id="@+id/player_loading"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/accent_gold"
        android:visibility="gone" />

    <!-- Error overlay with details -->
    <LinearLayout
        android:id="@+id/player_error"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="48dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Could not play this channel"
            android:textSize="26sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:gravity="center" />

        <TextView
            android:id="@+id/error_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/text_hint"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:maxLines="4"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/error_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#55FFFFFF"
            android:fontFamily="monospace"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:maxLines="2"
            android:ellipsize="middle" />

        <Button
            android:id="@+id/btn_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Retry"
            style="@style/LargeButton"
            android:layout_marginTop="24dp"
            android:focusable="true"
            android:focusableInTouchMode="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Press Back to return."
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="12dp" />
    </LinearLayout>

</FrameLayout>
