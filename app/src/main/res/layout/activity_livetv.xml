<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- Main layout: channel list left, player right -->
    <LinearLayout
        android:id="@+id/main_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- Channel list sidebar -->
        <LinearLayout
            android:id="@+id/channel_sidebar"
            android:layout_width="380dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/surface_dark"
            android:descendantFocusability="beforeDescendants"
            android:focusableInTouchMode="true">

            <!-- Search / channel number input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#22FFFFFF"
                android:paddingStart="16dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_voice_search"
                    android:scaleType="centerInside"
                    android:alpha="0.5"
                    android:contentDescription="Search" />

                <EditText
                    android:id="@+id/channel_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Search channels…"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:background="@android:color/transparent"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginStart="10dp"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true" />

                <!-- Favorites toggle -->
                <Button
                    android:id="@+id/btn_favorites"
                    android:layout_width="44dp"
                    android:layout_height="36dp"
                    android:text="★"
                    android:textSize="16sp"
                    android:textColor="@color/text_hint"
                    android:background="@drawable/card_selector"
                    android:minWidth="44dp"
                    android:minHeight="36dp"
                    android:layout_marginEnd="4dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true" />

                <!-- Open TV Guide -->
                <Button
                    android:id="@+id/btn_toggle_epg"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Guide"
                    android:textSize="14sp"
                    android:textColor="@color/accent_gold"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/card_selector"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:minHeight="36dp"
                    android:layout_marginEnd="4dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true" />

                <TextView
                    android:id="@+id/channel_count_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/text_hint"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <!-- Channel list -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/channel_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/no_results_text"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="No channels found"
                    android:textSize="18sp"
                    android:textColor="@color/text_hint"
                    android:fontFamily="sans-serif-light"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>

        <!-- Right side: mini player + now/next strip -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@android:color/black">

            <!-- Hint text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Double-click a channel to go full screen"
                android:textSize="13sp"
                android:textColor="@color/text_hint"
                android:fontFamily="sans-serif-light"
                android:gravity="center"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="#22000000" />

            <!-- Mini player -->
            <androidx.media3.ui.PlayerView
                android:id="@+id/mini_player"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                app:use_controller="false"
                app:resize_mode="fit" />

            <!-- Go to Channel button -->
            <Button
                android:id="@+id/btn_number_pad"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Go to Channel #"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/button_goto_channel"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <!-- Now playing / Up next strip -->
            <LinearLayout
                android:id="@+id/epg_strip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface_dark"
                android:padding="16dp">

                <!-- Current channel name -->
                <TextView
                    android:id="@+id/strip_channel_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Now playing -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/live_dot" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NOW"
                        android:textSize="12sp"
                        android:textColor="@color/status_online"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/strip_now_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/strip_now_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/text_hint"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>

                <!-- Progress bar -->
                <ProgressBar
                    android:id="@+id/strip_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginTop="6dp"
                    android:max="100"
                    android:progressTint="@color/accent_gold"
                    android:progressBackgroundTint="#22FFFFFF" />

                <!-- Up next -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NEXT"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/strip_next_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="15sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif-light"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/strip_next_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/text_hint"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Loading overlay -->
    <LinearLayout
        android:id="@+id/livetv_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@color/background_dark"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminateTint="@color/accent_gold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading channels…"
            android:textSize="20sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="12dp" />
    </LinearLayout>

</FrameLayout>
