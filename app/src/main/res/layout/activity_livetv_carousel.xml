<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero card -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="360dp">

                <androidx.media3.ui.PlayerView
                    android:id="@+id/car_hero_player"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:use_controller="false"
                    app:resize_mode="fit" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradient_bottom_scrim" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="bottom|start"
                    android:padding="32dp">

                    <TextView
                        android:id="@+id/car_hero_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NOW WATCHING"
                        android:textSize="12sp"
                        android:textColor="@color/accent_gold"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/car_hero_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="32sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/car_hero_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="sans-serif-light"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:layout_marginTop="4dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp">

                        <Button
                            android:id="@+id/car_btn_fullscreen"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="▶ Watch Fullscreen"
                            android:textColor="@color/accent_gold"
                            android:background="@drawable/card_selector"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:focusable="true"
                            android:focusableInTouchMode="true" />

                        <Button
                            android:id="@+id/car_btn_number_pad"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="Go to Channel #"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/card_selector"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:layout_marginStart="10dp"
                            android:focusable="true"
                            android:focusableInTouchMode="true" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- Search bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#22FFFFFF"
                android:paddingStart="32dp"
                android:paddingEnd="32dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_voice_search"
                    android:scaleType="centerInside"
                    android:alpha="0.5"
                    android:contentDescription="Search" />

                <EditText
                    android:id="@+id/car_channel_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Search channels…"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:background="@android:color/transparent"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginStart="10dp"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true" />
            </LinearLayout>

            <!-- Rows of channels by category -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/car_rows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:paddingBottom="32dp"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/car_no_results_text"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:gravity="center"
                android:text="No channels found"
                android:textSize="18sp"
                android:textColor="@color/text_hint"
                android:fontFamily="sans-serif-light"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/car_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@color/background_dark"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminateTint="@color/accent_gold" />
    </LinearLayout>

</FrameLayout>
