<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top: preview + info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="horizontal"
            android:background="@color/surface_dark"
            android:padding="16dp">

            <androidx.media3.ui.PlayerView
                android:id="@+id/epg_mini_player"
                android:layout_width="320dp"
                android:layout_height="match_parent"
                app:use_controller="false"
                app:resize_mode="fit" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/epg_channel_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="26sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/epg_program_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="@color/accent_gold"
                    android:fontFamily="sans-serif"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/epg_program_desc"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-light"
                    android:maxLines="4"
                    android:ellipsize="end"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/epg_btn_number_pad"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Go to Channel #"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/card_selector"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:layout_gravity="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- Search bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#18FFFFFF"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_voice_search"
                android:scaleType="centerInside"
                android:alpha="0.5"
                android:contentDescription="Search" />

            <EditText
                android:id="@+id/epg_channel_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Search channels…"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:background="@android:color/transparent"
                android:fontFamily="sans-serif-light"
                android:layout_marginStart="10dp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true" />
        </LinearLayout>

        <!-- Category picker (opens modal list on click) -->
        <Button
            android:id="@+id/epg_category_chips"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:minWidth="240dp"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/card_selector"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp"
            android:gravity="center_vertical|start"
            android:singleLine="true"
            android:ellipsize="end"
            android:focusable="true"
            android:focusableInTouchMode="true" />

        <!-- EPG channel+program list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/epg_channel_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/epg_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@color/background_dark"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminateTint="@color/accent_gold" />
    </LinearLayout>

</FrameLayout>
