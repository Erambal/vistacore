<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Huge preview (top ~65%) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="65">

            <androidx.media3.ui.PlayerView
                android:id="@+id/sh_player"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:use_controller="false"
                app:resize_mode="fit" />

            <View
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_bottom_scrim" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:padding="40dp">

                <TextView
                    android:id="@+id/sh_channel_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/accent_gold"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/sh_channel_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="36sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/sh_now_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-light"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp" />

                <ProgressBar
                    android:id="@+id/sh_now_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="240dp"
                    android:layout_height="3dp"
                    android:max="100"
                    android:progressTint="@color/accent_gold"
                    android:progressBackgroundTint="#33FFFFFF"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Bottom panel: categories + ribbon (~35%) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="35"
            android:orientation="vertical"
            android:background="#DD0A0A0A">

            <com.vistacore.launcher.ui.FocusTrappedRecyclerView
                android:id="@+id/sh_category_chips"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:paddingStart="40dp"
                android:paddingEnd="40dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:clipToPadding="false" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/sh_channel_ribbon"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:paddingStart="40dp"
                android:paddingEnd="40dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:clipToPadding="false" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sh_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@color/background_dark"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminateTint="@color/accent_gold" />
    </LinearLayout>

</FrameLayout>
