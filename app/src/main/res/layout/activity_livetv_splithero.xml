<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Huge preview (top ~65%) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="65">

            <androidx.media3.ui.PlayerView
                android:id="@+id/sh_player"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:use_controller="false"
                app:resize_mode="fit" />

            <View
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_bottom_scrim" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:padding="40dp">

                <TextView
                    android:id="@+id/sh_channel_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/accent_gold"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/sh_channel_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="36sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/sh_now_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-light"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="2dp" />

                <ProgressBar
                    android:id="@+id/sh_now_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="240dp"
                    android:layout_height="3dp"
                    android:max="100"
                    android:progressTint="@color/accent_gold"
                    android:progressBackgroundTint="#33FFFFFF"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Bottom panel: categories + ribbon (~35%) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="35"
            android:orientation="vertical"
            android:background="#DD0A0A0A">

            <!-- Search + Go To Channel -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="40dp"
                android:paddingEnd="40dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_voice_search"
                    android:scaleType="centerInside"
                    android:alpha="0.5"
                    android:contentDescription="Search" />

                <EditText
                    android:id="@+id/sh_channel_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Search channels…"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:background="@android:color/transparent"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginStart="10dp"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true" />

                <Button
                    android:id="@+id/sh_btn_number_pad"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Go to Channel #"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/card_selector"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginStart="8dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true" />
            </LinearLayout>

            <Button
                android:id="@+id/sh_category_chips"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:minWidth="240dp"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/card_selector"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginStart="40dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical|start"
                android:singleLine="true"
                android:ellipsize="end"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/sh_channel_ribbon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:paddingStart="40dp"
                    android:paddingEnd="40dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:clipToPadding="false" />

                <TextView
                    android:id="@+id/sh_no_results_text"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="No channels found"
                    android:textSize="18sp"
                    android:textColor="@color/text_hint"
                    android:fontFamily="sans-serif-light"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sh_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@color/background_dark"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminateTint="@color/accent_gold" />
    </LinearLayout>

</FrameLayout>
