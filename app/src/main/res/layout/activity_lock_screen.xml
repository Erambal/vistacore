<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF080C12">

    <!-- Subtle gradient overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/lock_screen_gradient" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center"
        android:gravity="center"
        android:padding="48dp">

        <!-- Lock icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒"
            android:textSize="64sp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VistaCore"
            android:textSize="36sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.04"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This device has been deactivated."
            android:textSize="20sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact your administrator to restore access."
            android:textSize="16sp"
            android:textColor="@color/text_hint"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="40dp" />

        <!-- Device ID for admin reference -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device ID"
            android:textSize="13sp"
            android:textColor="@color/text_hint"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/lock_device_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="18sp"
            android:textColor="@color/accent_gold"
            android:fontFamily="monospace"
            android:textIsSelectable="false"
            android:layout_marginBottom="48dp" />

        <Button
            android:id="@+id/btn_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Retry"
            style="@style/LargeButton"
            android:backgroundTint="@color/settings_gray"
            android:focusable="true"
            android:focusableInTouchMode="true" />
    </LinearLayout>
</FrameLayout>
