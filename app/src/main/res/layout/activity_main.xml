<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_margin_horizontal"
            android:paddingEnd="@dimen/screen_margin_horizontal"
            android:paddingTop="24dp"
            android:paddingBottom="32dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- ===== TOP BAR: Search + Remote Help + Settings ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <!-- Search bar -->
                <LinearLayout
                    android:id="@+id/search_bar"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/search_bar_background"
                    android:paddingStart="20dp"
                    android:paddingEnd="16dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:layout_marginEnd="16dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_voice_search"
                        android:scaleType="centerInside"
                        android:alpha="0.6"
                        android:contentDescription="Search" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Search channels &amp; shows…"
                        android:textSize="17sp"
                        android:textColor="@color/text_hint"
                        android:fontFamily="sans-serif-light"
                        android:layout_marginStart="12dp" />
                </LinearLayout>

                <!-- Remote Help Button -->
                <ImageButton
                    android:id="@+id/btn_remote_help"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_remote_help"
                    android:scaleType="centerInside"
                    android:background="@drawable/card_selector"
                    android:padding="10dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:contentDescription="Remote Help"
                    android:layout_marginEnd="8dp" />

                <!-- Settings Button -->
                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_settings"
                    android:scaleType="centerInside"
                    android:background="@drawable/card_selector"
                    android:padding="10dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:contentDescription="@string/cd_settings" />
            </LinearLayout>

            <!-- ===== CLOCK & DATE ===== -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="true"
                android:gravity="bottom"
                android:layout_marginBottom="28dp">

                <TextClock
                    android:id="@+id/clock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:format12Hour="h:mm"
                    android:format24Hour="HH:mm"
                    android:textSize="56sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-thin"
                    android:letterSpacing="0.02" />

                <TextClock
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:format12Hour=" a"
                    android:format24Hour=""
                    android:textSize="20sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginStart="4dp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="28dp"
                    android:background="#33FFFFFF"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp" />

                <TextClock
                    android:id="@+id/date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:format12Hour="EEEE, MMMM d"
                    android:format24Hour="EEEE, MMMM d"
                    android:textSize="20sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>

            <!-- ===== APP CARDS ===== -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/apps_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:overScrollMode="never"
                android:layout_marginBottom="8dp" />

            <!-- ===== CONTINUE WATCHING ===== -->
            <LinearLayout
                android:id="@+id/continue_watching_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Continue Watching"
                    android:textSize="22sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="true"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/continue_watching_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:overScrollMode="never" />
            </LinearLayout>

            <!-- ===== UPCOMING GAMES ===== -->

            <!-- ===== CHANNELS YOU'VE RECENTLY WATCHED (combined recents + EPG) ===== -->
            <LinearLayout
                android:id="@+id/guide_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Channels You've Recently Watched"
                        android:textSize="22sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:textAllCaps="true"
                        android:letterSpacing="0.04" />

                    <TextView
                        android:id="@+id/btn_full_guide"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full Guide →"
                        android:textSize="15sp"
                        android:textColor="@color/accent_gold"
                        android:fontFamily="sans-serif-medium"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:background="@drawable/card_selector"
                        android:padding="8dp" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/guide_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never" />

                <TextView
                    android:id="@+id/guide_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No recently watched channels."
                    android:textSize="16sp"
                    android:textColor="@color/text_hint"
                    android:fontFamily="sans-serif-light"
                    android:padding="16dp"
                    android:gravity="center"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Hidden recents views (kept for binding compatibility) -->
            <TextView android:id="@+id/recents_header" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/recents_row" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

            <!-- ===== UPCOMING GAMES ===== -->
            <LinearLayout
                android:id="@+id/games_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@drawable/section_divider"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_upcoming_games"
                    android:textSize="22sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="true"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/games_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:overScrollMode="never" />

                <ProgressBar
                    android:id="@+id/games_loading"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/accent_gold"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- (recently watched moved above apps) -->

            <!-- ===== FAVORITE CHANNELS ===== -->
            <TextView
                android:id="@+id/favorites_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_favorite_channels"
                android:textSize="22sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:textAllCaps="true"
                android:letterSpacing="0.06"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/favorites_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:overScrollMode="never"
                android:visibility="gone" />

            <!-- ===== NOW PLAYING ===== -->
            <LinearLayout
                android:id="@+id/now_playing_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_default"
                android:padding="20dp"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                android:focusable="true"
                android:focusableInTouchMode="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Now Playing"
                    android:textSize="14sp"
                    android:textColor="@color/accent_gold"
                    android:fontFamily="sans-serif-medium"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/now_playing_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/now_playing_channel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="2dp" />

                <ProgressBar
                    android:id="@+id/now_playing_progress"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progressTint="@color/accent_gold"
                    android:progressBackgroundTint="#22FFFFFF" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
