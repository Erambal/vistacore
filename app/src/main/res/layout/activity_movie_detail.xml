<?xml version="1.0" encoding="utf-8"?>
<!-- Movie detail: rich metadata, play button, cast row. Same visual
     language as activity_show_detail but no season/episode section. -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/detail_backdrop"
            android:layout_width="match_parent"
            android:layout_height="420dp"
            android:scaleType="centerCrop"
            android:contentDescription="@null"
            android:alpha="0.4" />

        <View
            android:layout_width="match_parent"
            android:layout_height="420dp"
            android:background="@drawable/detail_backdrop_scrim" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="32dp">

            <!-- Left: poster -->
            <ImageView
                android:id="@+id/movie_poster"
                android:layout_width="320dp"
                android:layout_height="480dp"
                android:scaleType="centerCrop"
                android:contentDescription="Movie poster"
                android:layout_marginEnd="32dp" />

            <!-- Right: metadata + play + cast -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/movie_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="34sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/movie_tagline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/accent_gold_light"
                    android:textStyle="italic"
                    android:visibility="gone"
                    android:layout_marginBottom="10dp"
                    tools:text="&quot;In space, no one can hear you scream.&quot;"
                    tools:visibility="visible" />

                <LinearLayout
                    android:id="@+id/movie_badges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/movie_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="14dp"
                    tools:text="Sci-Fi · USA · Dir. Ridley Scott" />

                <TextView
                    android:id="@+id/movie_plot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="18dp"
                    tools:text="The crew of a commercial starship…" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <Button
                        android:id="@+id/movie_play_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶  Play"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/background_dark"
                        android:background="@drawable/button_background"
                        android:paddingStart="28dp"
                        android:paddingEnd="28dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:layout_marginEnd="12dp" />

                    <Button
                        android:id="@+id/movie_trailer_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶  Trailer"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/button_outline"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>

                <!-- Cast section -->
                <TextView
                    android:id="@+id/cast_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CAST"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:textColor="@color/text_hint"
                    android:layout_marginBottom="10dp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/cast_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</androidx.core.widget.NestedScrollView>
