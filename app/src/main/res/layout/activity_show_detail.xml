<?xml version="1.0" encoding="utf-8"?>
<!-- Rich show detail: backdrop header + metadata column on the left,
     seasons / episodes / cast on the right. Matches activity_movie_detail
     — includes a muted auto-trailer over the backdrop and a fullscreen
     overlay launched by the Trailer button. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/detail_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/detail_backdrop"
                android:layout_width="match_parent"
                android:layout_height="360dp"
                android:scaleType="centerCrop"
                android:contentDescription="@null"
                android:alpha="0.35" />

            <WebView
                android:id="@+id/detail_backdrop_trailer"
                android:layout_width="match_parent"
                android:layout_height="360dp"
                android:alpha="0"
                android:visibility="gone"
                android:focusable="false"
                android:focusableInTouchMode="false" />

            <View
                android:layout_width="match_parent"
                android:layout_height="360dp"
                android:background="@drawable/detail_backdrop_scrim" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="360dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingEnd="24dp">

                    <ImageView
                        android:id="@+id/show_poster"
                        android:layout_width="match_parent"
                        android:layout_height="440dp"
                        android:scaleType="centerCrop"
                        android:contentDescription="Show poster"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/show_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="26sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="3"
                        android:ellipsize="end"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/show_tagline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/accent_gold_light"
                        android:textStyle="italic"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp"
                        tools:text="&quot;Winter is coming.&quot;"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/show_rated_line"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/detail_rated_line_background"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp"
                        android:visibility="gone"
                        android:layout_marginBottom="10dp"
                        tools:text="Rated TV-MA"
                        tools:visibility="visible" />

                    <LinearLayout
                        android:id="@+id/show_badges"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/show_meta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="12dp"
                        tools:text="Drama · USA · Dir. Jane Doe" />

                    <TextView
                        android:id="@+id/show_plot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingExtra="3dp"
                        android:layout_marginBottom="12dp"
                        tools:text="A sweeping epic…" />

                    <TextView
                        android:id="@+id/show_category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/accent_gold"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/show_episode_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="12dp" />

                    <Button
                        android:id="@+id/show_trailer_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶  Watch Trailer"
                        android:background="@drawable/button_outline"
                        android:textColor="@color/text_primary"
                        android:padding="12dp"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/season_tabs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:clipToPadding="false"
                        android:clipChildren="false"
                        android:overScrollMode="never" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/episode_list"
                        android:layout_width="match_parent"
                        android:layout_height="480dp"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:id="@+id/cast_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CAST"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="10dp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/cast_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
    </androidx.core.widget.NestedScrollView>

    <FrameLayout
        android:id="@+id/trailer_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <WebView
            android:id="@+id/trailer_fullscreen"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <Button
            android:id="@+id/trailer_close_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:text="✕  Close"
            android:textColor="@color/text_primary"
            android:background="@drawable/button_outline"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:focusable="true"
            android:focusableInTouchMode="true" />
    </FrameLayout>
</FrameLayout>
