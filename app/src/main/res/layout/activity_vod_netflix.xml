<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:clipChildren="false">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/netflix_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:overScrollMode="never"
        android:paddingTop="64dp"
        android:paddingBottom="40dp" />

    <!-- Search bar — floats at top, Disney+ style -->
    <LinearLayout
        android:id="@+id/search_overlay"
        android:layout_width="360dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/search_bar_background"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_voice_search"
            android:scaleType="centerInside"
            android:alpha="0.4"
            android:contentDescription="Search" />

        <EditText
            android:id="@+id/netflix_search_input"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="Search…"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@android:color/transparent"
            android:fontFamily="sans-serif-light"
            android:layout_marginStart="10dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true" />
    </LinearLayout>

    <!-- Loading overlay -->
    <LinearLayout
        android:id="@+id/netflix_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@color/background_dark"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/accent_gold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loading…"
            android:textSize="18sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/netflix_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="No content found."
        android:textSize="22sp"
        android:textColor="@color/text_secondary"
        android:visibility="gone" />

</FrameLayout>
