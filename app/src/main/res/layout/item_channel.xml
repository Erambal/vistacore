<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    style="@style/ChannelItemStyle"
    android:layout_marginBottom="8dp">

    <!-- Channel Logo -->
    <ImageView
        android:id="@+id/channel_logo"
        android:layout_width="@dimen/channel_logo_size"
        android:layout_height="@dimen/channel_logo_size"
        android:scaleType="centerCrop"
        android:contentDescription="@string/cd_channel_logo" />

    <!-- Channel Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="16dp">

        <!-- Channel Name -->
        <TextView
            android:id="@+id/channel_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_channel_name"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Now Playing (EPG) -->
        <TextView
            android:id="@+id/channel_now_playing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/accent_gold"
            android:fontFamily="sans-serif-light"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Favorite toggle -->
    <ImageButton
        android:id="@+id/btn_favorite"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_favorite_outline"
        android:scaleType="centerInside"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:focusable="true"
        android:contentDescription="Toggle favorite"
        android:layout_marginEnd="8dp" />

    <!-- Channel Number -->
    <TextView
        android:id="@+id/channel_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="sans-serif-light" />
</LinearLayout>
