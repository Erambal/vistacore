<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/channel_item_background"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:layout_marginBottom="2dp"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <!-- Channel Logo -->
    <ImageView
        android:id="@+id/guide_channel_logo"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:scaleType="centerCrop"
        android:contentDescription="@string/cd_channel_logo" />

    <!-- Channel Name -->
    <TextView
        android:id="@+id/guide_channel_name"
        android:layout_width="140dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="12dp" />

    <!-- Current Program -->
    <TextView
        android:id="@+id/guide_program_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="17sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="12dp" />

    <!-- Time -->
    <TextView
        android:id="@+id/guide_program_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/text_hint"
        android:fontFamily="sans-serif-light"
        android:layout_marginStart="12dp" />

    <!-- Live indicator -->
    <View
        android:id="@+id/guide_live_dot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@color/status_online"
        android:layout_marginStart="8dp"
        android:visibility="gone" />

</LinearLayout>
