<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:background="@drawable/card_selector"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <TextView
        android:id="@+id/lvrow_number"
        android:layout_width="44dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="@color/accent_gold"
        android:fontFamily="sans-serif-medium"
        android:gravity="center" />

    <ImageView
        android:id="@+id/lvrow_logo"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="fitCenter"
        android:layout_marginStart="8dp"
        android:contentDescription="Logo" />

    <TextView
        android:id="@+id/lvrow_name"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="10dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/lvrow_now"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:ellipsize="end" />

        <ProgressBar
            android:id="@+id/lvrow_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100"
            android:progressTint="@color/accent_gold"
            android:progressBackgroundTint="#22FFFFFF"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/lvrow_next"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/text_hint"
        android:fontFamily="sans-serif-light"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="16dp" />
</LinearLayout>
