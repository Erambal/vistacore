<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="400dp"
    android:layout_marginBottom="24dp">

    <!-- Full-width background image. Always visible; the trailer WebView
         overlays it once the YouTube iframe reports the video is playing. -->
    <ImageView
        android:id="@+id/banner_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="Featured" />

    <!-- Muted YouTube trailer that fades in over the image a couple of
         seconds after the banner appears. Hidden by default — made visible
         in BannerVH.bind when we have a trailer id. -->
    <WebView
        android:id="@+id/banner_trailer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:alpha="0"
        android:focusable="false"
        android:focusableInTouchMode="false" />

    <!-- Gradient fade to background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/banner_gradient" />

    <!-- Content overlay -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:orientation="vertical"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:paddingBottom="40dp"
        android:maxWidth="600dp">

        <TextView
            android:id="@+id/banner_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/accent_gold"
            android:fontFamily="sans-serif"
            android:textAllCaps="true"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/banner_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="40sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif"
            android:fontStyle="normal"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingExtra="-2dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/banner_play"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:text="▶  Play"
                android:textSize="18sp"
                android:textColor="@color/background_dark"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/button_background"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:focusable="true"
                android:focusableInTouchMode="true" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
