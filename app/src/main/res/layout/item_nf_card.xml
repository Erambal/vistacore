<?xml version="1.0" encoding="utf-8"?>
<!-- Warm Cinema tile for the Netflix home. The inner card (nf_card) carries a
     rounded background and is clipped to its outline in code, so the poster /
     logo art and the title bar are rounded together as one card. Art zone shows
     a poster, a channel logo on a cream chip, or — when there's no artwork — a
     big colored monogram so the tile is never an unidentifiable empty box. The
     title is ALWAYS spelled out in the bar below, kept short so a whole row of
     names is readable on screen without scrolling. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="180dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/home_tile_selector"
    android:padding="5dp"
    android:layout_marginEnd="16dp"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/nf_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/nf_card_bg">

        <FrameLayout
            android:id="@+id/nf_art"
            android:layout_width="match_parent"
            android:layout_height="116dp"
            android:background="@color/nf_surface">

            <ImageView
                android:id="@+id/nf_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/nf_monogram"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="@color/nf_ink"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.02"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/nf_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="46dp"
            android:background="@color/nf_label_bg"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/nf_cream"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

</LinearLayout>
