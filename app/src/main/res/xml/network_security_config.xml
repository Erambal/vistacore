<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- IPTV streams use plain HTTP - allow cleartext traffic to all domains -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
